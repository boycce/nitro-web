{
  "_note": "Development-only ts configuration.",
  "_note_about_compilerOptions_paths": "Since the types for the package exports are not available in the package itself during development, we need to help the compiler find the types for these aliased paths.",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "allowSyntheticDefaultImports": true,
    "downlevelIteration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["es6", "dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "noImplicitReturns": false,
    "noImplicitThis": true,
    "noStrictGenericChecks": false,
    "paths": {
      "nitro-web/server": ["./server/index.ts"],
      "nitro-web/util": ["./util.ts"],
      "types": ["./types.ts"],
    },
    "resolveJsonModule": true,
    "rootDir": "./",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022"
  },
  "include": [
    "client",
    "components",
    "server"
  ]
}